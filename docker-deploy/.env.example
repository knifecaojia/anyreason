# ===================================================================
# AnyReason AI Studio 部署环境变量配置
# 使用方法：复制此文件为 .env 并修改标记为 <请修改> 的值
#   cp .env.example .env
# ===================================================================

# ===== PostgreSQL 配置 =====
POSTGRES_PORT=5432              # PostgreSQL 对外端口
POSTGRES_DB=anyreason           # 数据库名称
POSTGRES_USER=postgres          # 超级用户名
POSTGRES_PASSWORD=<请修改>       # 超级用户密码
APP_DB_USER=anyreason_app       # 应用用户名
APP_DB_PASSWORD=<请修改>         # 应用用户密码

# ===== MinIO 配置 =====
MINIO_API_PORT=9000             # MinIO API 端口
MINIO_CONSOLE_PORT=9001         # MinIO 控制台端口
MINIO_ROOT_USER=minioadmin      # MinIO 管理员用户名
MINIO_ROOT_PASSWORD=<请修改>     # MinIO 管理员密码
MINIO_BUCKET_ASSETS=anyreason-assets      # 资产存储桶名称
MINIO_BUCKET_EXPORTS=anyreason-exports    # 导出存储桶名称
MINIO_BUCKET_SCRIPTS=anyreason-scripts    # 脚本存储桶名称

# ===== Redis 配置 =====
REDIS_PASSWORD=<请修改>          # Redis 密码

# ===== 应用端口 =====
BACKEND_PORT=8000               # 后端 API 端口（内部）
FRONTEND_PORT=3000              # 前端端口（内部）

# ===== 安全密钥 =====
ACCESS_SECRET_KEY=<请修改>       # 访问令牌密钥
RESET_PASSWORD_SECRET_KEY=<请修改>   # 重置密码令牌密钥
VERIFICATION_SECRET_KEY=<请修改>     # 邮箱验证令牌密钥

# ===== 域名与 CORS =====
DOMAIN=ai.znxview.com                       # 部署域名
CORS_ORIGINS=https://ai.znxview.com     # 允许的跨域来源（逗号分隔，如 https://a.com,https://b.com）
FRONTEND_URL=https://ai.znxview.com         # 前端访问地址
USE_CDN=true                                # 是否使用 CDN（CDN 负责 SSL 终止，nginx 只监听 HTTP）

# ===== 管理员账户 =====
CREATE_DEFAULT_ADMIN=true                   # 是否创建默认管理员账户
DEFAULT_ADMIN_EMAIL=admin@example.com       # 管理员邮箱
DEFAULT_ADMIN_PASSWORD=<请修改>              # 管理员密码

# ===== Docker Hub 镜像配置（仅 deploy-hub.sh 使用）=====
DOCKER_REGISTRY=knifeandcj/anyreason        # Docker Hub 镜像仓库
BACKEND_TAG=backend-latest                  # 后端镜像标签
FRONTEND_TAG=frontend-latest                # 前端镜像标签
