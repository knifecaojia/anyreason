{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scenes Schema",
  "description": "AI漫剧场景数据结构",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "total_scenes": {
      "type": "integer",
      "minimum": 1
    },
    "scenes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/scene"
      }
    }
  },
  "required": ["version", "total_scenes", "scenes"],
  "definitions": {
    "scene": {
      "type": "object",
      "properties": {
        "scene_id": {
          "type": "string",
          "pattern": "^EP[0-9]{3}_SC[0-9]{2}$"
        },
        "episode_id": {
          "type": "string",
          "pattern": "^EP[0-9]{3}$"
        },
        "scene_number": {
          "type": "integer",
          "minimum": 1
        },
        "scene_code": {
          "type": "string",
          "pattern": "^[0-9]+-[0-9]+$"
        },
        "title": {
          "type": "string"
        },
        "time": {
          "type": "string"
        },
        "location_type": {
          "type": "string",
          "enum": ["内", "外", "内外"]
        },
        "location": {
          "type": "string"
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "shot_count": {
          "type": "integer",
          "minimum": 0
        },
        "content": {
          "type": "string",
          "description": "该场景完整原文（保留换行）"
        },
        "content_start_pos": {
          "type": "integer",
          "minimum": 0,
          "description": "场景原文在原始剧本文本中的字符起始位置（0-based）"
        },
        "content_end_pos": {
          "type": "integer",
          "minimum": 0,
          "description": "场景原文在原始剧本文本中的字符结束位置（0-based, exclusive）"
        },
        "summary": {
          "type": "string"
        },
        "key_events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emotional_tone": {
          "type": "string"
        },
        "start_line": {
          "type": "integer"
        },
        "end_line": {
          "type": "integer"
        }
      },
      "required": ["scene_id", "episode_id", "scene_number", "title"]
    }
  }
}
