{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Assets Schema",
  "description": "AI漫剧资产数据结构",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "total_assets": {
      "type": "integer",
      "minimum": 0
    },
    "assets": {
      "type": "object",
      "properties": {
        "characters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/character"
          }
        },
        "scenes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/scene"
          }
        },
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/prop"
          }
        },
        "vfx": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/vfx"
          }
        }
      }
    }
  },
  "required": ["version", "total_assets", "assets"],
  "definitions": {
    "character": {
      "type": "object",
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^CHAR_[0-9]{3}$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "character"
        },
        "category": {
          "type": "string",
          "enum": ["主角", "配角", "反派", "群演", "非人形"]
        },
        "description": {
          "type": "string"
        },
        "age": {
          "type": "string"
        },
        "gender": {
          "type": "string"
        },
        "height": {
          "type": "string"
        },
        "body_type": {
          "type": "string"
        },
        "hair": {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "style": {
              "type": "string"
            },
            "length": {
              "type": "string"
            }
          }
        },
        "eyes": {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "shape": {
              "type": "string"
            }
          }
        },
        "clothing": {
          "type": "object",
          "properties": {
            "default": {
              "type": "string"
            },
            "variants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "distinctive_features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "first_appearance": {
          "type": "string"
        },
        "appearances": {
          "type": "integer"
        },
        "prompt_template": {
          "type": "string"
        }
      },
      "required": ["asset_id", "name", "type", "description"]
    },
    "scene": {
      "type": "object",
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^SCENE_[0-9]{3}$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "scene"
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "time_of_day": {
          "type": "string"
        },
        "weather": {
          "type": "string"
        },
        "mood": {
          "type": "string"
        },
        "key_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "first_appearance": {
          "type": "string"
        },
        "appearances": {
          "type": "integer"
        },
        "z_depth": {
          "type": "object",
          "properties": {
            "foreground": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "midground": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "background": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "prompt_template": {
          "type": "string"
        }
      },
      "required": ["asset_id", "name", "type", "description"]
    },
    "prop": {
      "type": "object",
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^PROP_[0-9]{3}$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "prop"
        },
        "category": {
          "type": "string",
          "enum": ["武器", "道具", "食物", "载具", "装饰品", "其他"]
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "first_appearance": {
          "type": "string"
        },
        "appearances": {
          "type": "integer"
        },
        "prompt_template": {
          "type": "string"
        }
      },
      "required": ["asset_id", "name", "type", "description"]
    },
    "vfx": {
      "type": "object",
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^VFX_[0-9]{3}$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "vfx"
        },
        "category": {
          "type": "string",
          "enum": ["UI", "能量", "粒子", "变形", "环境", "其他"]
        },
        "description": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "animation": {
          "type": "string"
        },
        "first_appearance": {
          "type": "string"
        },
        "appearances": {
          "type": "integer"
        },
        "prompt_template": {
          "type": "string"
        }
      },
      "required": ["asset_id", "name", "type", "description"]
    }
  }
}
