{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Prompts Schema",
  "description": "AI漫剧视频提示词数据结构",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "total_prompts": {
      "type": "integer",
      "minimum": 0
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/prompt"
      }
    }
  },
  "required": ["version", "total_prompts", "prompts"],
  "definitions": {
    "prompt": {
      "type": "object",
      "properties": {
        "shot_id": {
          "type": "string",
          "pattern": "^EP[0-9]{3}_SC[0-9]{2}_SH[0-9]{2}$"
        },
        "scene_id": {
          "type": "string",
          "pattern": "^EP[0-9]{3}_SC[0-9]{2}$"
        },
        "episode_id": {
          "type": "string",
          "pattern": "^EP[0-9]{3}$"
        },
        "prompt": {
          "type": "string",
          "description": "主提示词（中文方括号格式）"
        },
        "negative_prompt": {
          "type": "string",
          "description": "负面提示词"
        },
        "style": {
          "type": "string",
          "enum": ["anime", "realistic", "3d", "sketch"]
        },
        "aspect_ratio": {
          "type": "string",
          "enum": ["16:9", "9:16", "4:3", "1:1", "21:9"]
        },
        "duration": {
          "type": "number",
          "description": "目标时长（秒）"
        },
        "camera_settings": {
          "type": "object",
          "properties": {
            "shot_type": {
              "type": "string"
            },
            "angle": {
              "type": "string"
            },
            "movement": {
              "type": "string"
            },
            "focus": {
              "type": "string"
            }
          }
        },
        "character_prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "character": {
                "type": "string"
              },
              "prompt": {
                "type": "string"
              },
              "action": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            }
          }
        },
        "scene_prompt": {
          "type": "string"
        },
        "special_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reference_assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generation_notes": {
          "type": "string"
        }
      },
      "required": ["shot_id", "prompt"]
    }
  }
}
