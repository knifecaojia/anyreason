{
  "task": "6 - Backend Transaction/Event Traceability Enhancements",
  "component": "User Transactions Response",
  "date": "2026-03-22",
  
  "schema_contract": {
    "CreditTransactionRead": {
      "base_fields": [
        "id: UUID",
        "user_id: UUID",
        "delta: int",
        "balance_after: int",
        "reason: str",
        "actor_user_id: UUID | null",
        "meta: dict[str, Any]",
        "created_at: datetime"
      ],
      "computed_traceability_fields": [
        {
          "name": "trace_type",
          "type": "str | None",
          "description": "Discriminator: 'ai', 'agent', 'admin', or 'init'"
        },
        {
          "name": "operation_display",
          "type": "str | None",
          "description": "Human-readable operation description"
        },
        {
          "name": "is_refund",
          "type": "bool",
          "description": "Whether this is a refund transaction"
        },
        {
          "name": "linked_event_id",
          "type": "UUID | None",
          "description": "Linked AIUsageEvent ID for correlation"
        },
        {
          "name": "category",
          "type": "str | None",
          "description": "AI operation category (text/image/video)"
        },
        {
          "name": "model_display",
          "type": "str | None",
          "description": "Model name for display"
        }
      ]
    }
  },

