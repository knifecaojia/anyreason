POSTGRES_PORT=5432
POSTGRES_DB=anyreason
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
APP_DB_USER=anyreason_app
APP_DB_PASSWORD=anyreason_app

# Object Storage Provider: "minio" (default, local dev) or "cos" (Tencent COS)
# OBJECT_STORAGE_PROVIDER=minio

# MinIO (S3 compatible object storage — used when OBJECT_STORAGE_PROVIDER=minio)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET_ASSETS=anyreason-assets
MINIO_BUCKET_EXPORTS=anyreason-exports
MINIO_BUCKET_SCRIPTS=anyreason-scripts

# Tencent COS (required when OBJECT_STORAGE_PROVIDER=cos)
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_REGION=ap-shanghai
# COS_BUCKET=your-bucket-appid
# COS_DOMAIN=https://your-bucket-appid.cos.ap-shanghai.myqcloud.com

REDIS_PORT=6379
REDIS_PASSWORD=redis

BACKEND_PORT=8000
FRONTEND_PORT=3000

ACCESS_SECRET_KEY=dev-access-secret-change-me
RESET_PASSWORD_SECRET_KEY=dev-reset-password-secret-change-me
VERIFICATION_SECRET_KEY=dev-verification-secret-change-me
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000

CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123

NEXT_PUBLIC_DEV_LOGIN_PREFILL=true
NEXT_PUBLIC_DEV_LOGIN_EMAIL=admin@example.com
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=admin123

PYTHON_BASE_IMAGE=python:3.12-bookworm
NODE_BASE_IMAGE=node:20-bookworm

LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=litellm123
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_SALT_KEY=change-me
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=admin123
LITELLM_ADMIN_USER_ID=admin
LITELLM_ADMIN_EMAIL=admin@example.com
LITELLM_WEBHOOK_URL=http://backend:8000/api/v1/llm/webhooks/litellm
LITELLM_WEBHOOK_SECRET=change-me
LITELLM_DEFAULT_ALLOWED_MODELS=mock,deepseek
LITELLM_VIRTUAL_KEY_ALLOWED_MODELS=*
DEEPSEEK_API_KEY=
HTTP_PROXY=http://10.18.12.24:10809
HTTPS_PROXY=http://10.18.12.24:10809
http_proxy=http://10.18.12.24:10809
https_proxy=http://10.18.12.24:10809
NO_PROXY=localhost,127.0.0.1,postgres
