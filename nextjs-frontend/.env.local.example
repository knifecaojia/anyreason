# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT CONFIGURATION
# =============================================================================
# This file is for LOCAL DEVELOPMENT ONLY - do NOT use in production
# Copy this file to .env.local for local development
# =============================================================================

# -----------------------------------------------------------------------------
# LOCAL DEV: Backend API Configuration
# -----------------------------------------------------------------------------

# LOCAL DEV ONLY - SSR uses this to call backend API running on localhost
# Production: Use INTERNAL_API_BASE_URL in .env (not this file)
INTERNAL_API_BASE_URL=http://localhost:8000

# LOCAL DEV: Browser uses relative /api (no NEXT_PUBLIC_API_BASE_URL needed)
# The frontend's browser code calls /api/* which proxies to the backend
# Only set NEXT_PUBLIC_API_BASE_URL for explicit split-origin deployments

# OpenAPI generated file (local development)
OPENAPI_OUTPUT_FILE=../local-shared-data/openapi.json

# -----------------------------------------------------------------------------
# LOCAL DEV: Mock API (optional)
# -----------------------------------------------------------------------------

# Set to true to use mock API responses instead of calling backend
NEXT_PUBLIC_USE_MOCK_API=false
USE_MOCK_API=false

# -----------------------------------------------------------------------------
# LOCAL DEV: Developer Login Helper (optional)
# -----------------------------------------------------------------------------

# Pre-fill login form with credentials for easier local testing
NEXT_PUBLIC_DEV_LOGIN_PREFILL=true
NEXT_PUBLIC_DEV_LOGIN_EMAIL=admin@example.com
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=12345678
