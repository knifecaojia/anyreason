# =============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================
# This file is a TEMPLATE for deployment. Do NOT use localhost values here.
# For local development, use .env.local (see .env.local.example)
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------

# SSR (Server-Side Rendering) uses this to call backend API
# For production: Set to your actual backend URL (e.g., http://backend:8000 or https://api.example.com)
INTERNAL_API_BASE_URL=http://your-backend-host:8000

# Browser uses relative /api by default (no NEXT_PUBLIC_API_BASE_URL needed)
# Only set this if you have an explicit split-origin deployment (e.g., Vercel frontend + separate backend host)
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-host:8000

# OpenAPI generated file name (relative to the frontend directory)
OPENAPI_OUTPUT_FILE=../local-shared-data/openapi.json
